# Copy this file to `.env` and edit the values you need.

# General
CLAW_PROVIDER=poe
CLAW_MODEL=claude-sonnet-4-6
CLAW_PERMISSION_MODE=workspace-write
CLAW_DEFAULT_PROMPT="summarize this workspace"

# Rust / binary
RUST_DIR=/home/yang/Downloads/clawcode/rust
CLAW_BIN=/home/yang/Downloads/clawcode/rust/target/release/claw

# Poe / Anthropic-compatible mode
POE_API_KEY=
POE_BASE_URL=https://api.poe.com

# OpenAI-compatible local mode
OPENAI_API_KEY=local-test-key
OPENAI_BASE_URL=http://127.0.0.1:8011/v1
LOCAL_MODEL_ALIAS=claw-local-model
LOCAL_MODEL_ROOT=/home/yang/Downloads/pretrained
LOCAL_ALLOWED_TOOLS=read,glob,grep,edit,write,TodoWrite

# Local serving environment
CONDA_ENV_PREFIX=/home/yang/miniconda3/envs/claw-local
LOCAL_MODEL_REF=/home/yang/Downloads/pretrained/Qwen3-4B
LOCAL_SERVER_HOST=127.0.0.1
LOCAL_SERVER_PORT=8011
LOCAL_SERVER_DEVICE=auto
LOCAL_SERVER_DTYPE=auto
LOCAL_SERVER_ENABLE_CORS=true
LOCAL_SERVER_CONTINUOUS_BATCHING=false
LOCAL_SERVER_PORT_SEARCH_LIMIT=20
LOCAL_SERVER_STATE_FILE=/home/yang/Downloads/clawcode/.claw/local-server.env
